# ============================================
# CipherLink — Vercel Environment Variables
# ============================================
# Set these in: Vercel Dashboard → Project Settings → Environment Variables
# Select "Production" environment for all variables.
#
# IMPORTANT: Do NOT commit real values to git. This file is a template only.

# ─── REQUIRED ────────────────────────────────────────────────────────

# Supabase PostgreSQL connection (use the Transaction Pooler URL)
# Found at: Supabase Dashboard → Settings → Database → Connection String → Transaction
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase project URL (for any direct Supabase SDK calls)
SUPABASE_URL=https://[PROJECT_REF].supabase.co

# Supabase anonymous/public key (safe to expose client-side)
SUPABASE_ANON_KEY=eyJ...your-anon-key...

# CORS allowed origins — your Vercel deployment URL(s), comma-separated
# MUST include your actual domain, otherwise all API requests will be blocked
ALLOWED_ORIGINS=https://your-app.vercel.app

# Production mode — MUST be "production" on Vercel
NODE_ENV=production
