# ============================================
# CipherLink — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# Do NOT push .env with real credentials to git.

# Database Connection (Supabase Transaction Pooler)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase Configuration (Server-Side — used by broadcast.ts for Realtime REST API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Optional: Service role key for server-to-server broadcast (preferred over anon key)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Client-Side Supabase config (Vite requires VITE_ prefix to expose to browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# CORS — Update this to your actual Vercel deployment URL after first deploy
ALLOWED_ORIGINS=https://your-app.vercel.app

# Production mode
NODE_ENV=production

# Required in production — protects the /api/internal/cleanup cron endpoint
# CRON_SECRET=your-cron-secret
